{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Pixlox/Koma/blob/main/connectors/connector.schema.json",
  "title": "Koma connector package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "sourcePattern",
    "requestUrl",
    "allowedRequestHosts",
    "allowedPageHosts",
    "mapping"
  ],
  "oneOf": [
    {
      "properties": {
        "mapping": {
          "type": "object",
          "required": [
            "chapterPages"
          ]
        }
      }
    },
    {
      "required": [
        "pageRequestUrl"
      ],
      "properties": {
        "mapping": {
          "type": "object",
          "required": [
            "pageResponsePages"
          ]
        }
      }
    }
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$",
      "minLength": 3,
      "maxLength": 64
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "description": {
      "type": "string",
      "maxLength": 280
    },
    "sourcePattern": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "requestUrl": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "pageRequestUrl": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "allowedRequestHosts": {
      "$ref": "#/$defs/hosts"
    },
    "allowedPageHosts": {
      "$ref": "#/$defs/hosts"
    },
    "allowLocalNetwork": {
      "type": "boolean",
      "default": false
    },
    "capabilities": {
      "type": "array",
      "items": {
        "enum": [
          "chapter",
          "volume",
          "series"
        ]
      },
      "contains": {
        "const": "series"
      },
      "uniqueItems": true,
      "default": [
        "series"
      ]
    },
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "chapters",
        "chapterNumber"
      ],
      "properties": {
        "title": {
          "$ref": "#/$defs/pointer"
        },
        "language": {
          "$ref": "#/$defs/pointer"
        },
        "chapters": {
          "$ref": "#/$defs/pointer"
        },
        "chapterNumber": {
          "$ref": "#/$defs/pointer"
        },
        "chapterVolume": {
          "$ref": "#/$defs/pointer"
        },
        "chapterPages": {
          "$ref": "#/$defs/pointer"
        },
        "pageResponsePages": {
          "$ref": "#/$defs/pointer"
        },
        "pageUrl": {
          "$ref": "#/$defs/pointer"
        },
        "pageWidth": {
          "$ref": "#/$defs/pointer"
        },
        "pageHeight": {
          "$ref": "#/$defs/pointer"
        }
      }
    }
  },
  "$defs": {
    "pointer": {
      "type": "string",
      "pattern": "^/"
    },
    "hosts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?:\\*\\.)?[A-Za-z0-9](?:[A-Za-z0-9.-]{0,251}[A-Za-z0-9])?$"
      }
    }
  }
}
