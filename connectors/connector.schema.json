{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Pixlox/Koma/blob/main/connectors/connector.schema.json",
  "title": "Koma connector package",
  "description": "Schema v1 declarative and schema v2 hybrid JSON/Rhai connector packages.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "sourcePattern",
    "requestUrl",
    "allowedRequestHosts",
    "allowedPageHosts",
    "mapping"
  ],
  "allOf": [
    {
      "oneOf": [
        {
          "properties": {
            "mapping": {
              "required": [
                "chapterPages"
              ]
            }
          }
        },
        {
          "required": [
            "pageRequestUrl"
          ],
          "properties": {
            "mapping": {
              "required": [
                "pageResponsePages"
              ]
            }
          }
        }
      ]
    },
    {
      "if": {
        "properties": {
          "schemaVersion": {
            "const": 1
          }
        }
      },
      "then": {
        "properties": {
          "responseType": {
            "const": "json"
          }
        },
        "not": {
          "required": [
            "transformScript"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "responseType": {
            "const": "text"
          }
        },
        "required": [
          "responseType"
        ]
      },
      "then": {
        "properties": {
          "schemaVersion": {
            "const": 2
          }
        },
        "required": [
          "transformScript"
        ]
      }
    }
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "enum": [
        1,
        2
      ]
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$",
      "minLength": 3,
      "maxLength": 64
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "description": {
      "type": "string",
      "maxLength": 280
    },
    "sourcePattern": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "requestUrl": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "pageRequestUrl": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "allowedRequestHosts": {
      "$ref": "#/$defs/hosts"
    },
    "allowedPageHosts": {
      "$ref": "#/$defs/hosts"
    },
    "allowLocalNetwork": {
      "type": "boolean",
      "default": false
    },
    "responseType": {
      "enum": [
        "json",
        "text"
      ],
      "default": "json"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "enum": [
          "chapter",
          "volume",
          "series"
        ]
      },
      "contains": {
        "const": "series"
      },
      "uniqueItems": true,
      "default": [
        "series"
      ]
    },
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "chapters",
        "chapterNumber"
      ],
      "properties": {
        "title": {
          "$ref": "#/$defs/pointer"
        },
        "language": {
          "$ref": "#/$defs/pointer"
        },
        "chapters": {
          "$ref": "#/$defs/pointer"
        },
        "chapterNumber": {
          "$ref": "#/$defs/pointer"
        },
        "chapterVolume": {
          "$ref": "#/$defs/pointer"
        },
        "chapterPages": {
          "$ref": "#/$defs/pointer"
        },
        "pageResponsePages": {
          "$ref": "#/$defs/pointer"
        },
        "pageUrl": {
          "$ref": "#/$defs/pointer"
        },
        "pageWidth": {
          "$ref": "#/$defs/pointer"
        },
        "pageHeight": {
          "$ref": "#/$defs/pointer"
        }
      }
    },
    "transformScript": {
      "type": "string",
      "minLength": 1,
      "maxLength": 262144,
      "description": "Schema v2 Rhai script that returns the JSON value consumed by mapping. Scripts may use Koma's guarded http(method, url, headers, body) helper."
    },
    "settings": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "maxLength": 4096
      },
      "description": "Connector-defined values exposed to Rhai as the settings map."
    }
  },
  "$defs": {
    "pointer": {
      "type": "string",
      "pattern": "^/"
    },
    "hosts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?:\\*\\.)?[A-Za-z0-9](?:[A-Za-z0-9.-]{0,251}[A-Za-z0-9])?$"
      }
    }
  }
}
