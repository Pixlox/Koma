{
  "exampleType": "native-connector-reference",
  "provider": "MangaFire",
  "implementation": "crates/koma-core/src/importer/mod.rs",
  "capabilities": [
    "chapter",
    "volume",
    "series"
  ],
  "acceptedSources": [
    "https://mangafire.to/title/{title-key}",
    "https://mangafire.to/title/{title-key}/volume/{volume-id}"
  ],
  "requests": [
    {
      "purpose": "title metadata",
      "path": "/api/titles/{title-hid}"
    },
    {
      "purpose": "volume list",
      "path": "/api/titles/{title-hid}/volumes"
    },
    {
      "purpose": "selected volume",
      "path": "/api/volumes/{volume-id}"
    },
    {
      "purpose": "paginated official chapter list",
      "path": "/api/titles/{title-hid}/chapters"
    },
    {
      "purpose": "chapter pages",
      "path": "/api/chapters/{chapter-id}"
    }
  ],
  "safety": [
    "exact source host and scheme",
    "public DNS addresses only",
    "bounded JSON and image bodies",
    "provider response identity checks",
    "finite 429 and 5xx retries",
    "paced chapter metadata requests",
    "validated image data",
    "atomic CBZ output"
  ]
}
