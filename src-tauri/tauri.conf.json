{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Koma",
  "version": "0.1.2",
  "identifier": "me.pixlox.koma",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Koma",
        "width": 1280,
        "height": 820,
        "minWidth": 320,
        "minHeight": 480,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "'self' ipc: asset: http://ipc.localhost http://asset.localhost",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:"
      },
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Pixlox",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Entertainment",
    "shortDescription": "A fast, local-first comic and manga reader.",
    "longDescription": "Koma is a native-minimal, local-first reader and library for comic and manga archives.",
    "copyright": "Copyright © 2026 Pixlox",
    "createUpdaterArtifacts": true,
    "fileAssociations": [
      {
        "ext": [
          "cbz"
        ],
        "mimeType": "application/vnd.comicbook+zip",
        "name": "Comic Book ZIP",
        "role": "Viewer",
        "rank": "Alternate",
        "exportedType": {
          "identifier": "me.pixlox.koma.cbz",
          "conformsTo": [
            "public.zip-archive",
            "public.data"
          ]
        }
      },
      {
        "ext": [
          "cbr"
        ],
        "mimeType": "application/vnd.comicbook-rar",
        "name": "Comic Book RAR",
        "role": "Viewer",
        "rank": "Alternate",
        "exportedType": {
          "identifier": "me.pixlox.koma.cbr",
          "conformsTo": [
            "public.data"
          ]
        }
      },
      {
        "ext": [
          "cb7"
        ],
        "mimeType": "application/x-7z-compressed",
        "name": "Comic Book 7z",
        "role": "Viewer",
        "rank": "Alternate",
        "exportedType": {
          "identifier": "me.pixlox.koma.cb7",
          "conformsTo": [
            "public.archive",
            "public.data"
          ]
        }
      },
      {
        "ext": [
          "cbt"
        ],
        "mimeType": "application/x-tar",
        "name": "Comic Book TAR",
        "role": "Viewer",
        "rank": "Alternate",
        "exportedType": {
          "identifier": "me.pixlox.koma.cbt",
          "conformsTo": [
            "public.archive",
            "public.data"
          ]
        }
      },
      {
        "ext": [
          "epub"
        ],
        "mimeType": "application/epub+zip",
        "name": "Fixed-layout EPUB",
        "role": "Viewer",
        "rank": "Alternate"
      },
      {
        "ext": [
          "pdf"
        ],
        "mimeType": "application/pdf",
        "name": "PDF document",
        "role": "Viewer",
        "rank": "Alternate"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBNzVGN0JBNUU3RUI2NDcKUldSSHRuNWV1dmQxaWoxNFQ4VHl2akpMZlRqcWVVNU9GbTlnSVk0MHY5cnRVeDVrWjhtZENJQlYK",
      "endpoints": [
        "https://github.com/Pixlox/Koma/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
