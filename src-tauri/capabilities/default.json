{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "The smallest capability set required by Koma's main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:allow-reveal-item-in-dir"
  ]
}
